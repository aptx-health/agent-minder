{
  "$schema": "https://lnav.org/schemas/format-v1.schema.json",
  "agent_minder_log": {
    "title": "agent-minder debug log",
    "description": "Structured JSON logs from agent-minder's two-tier LLM pipeline",
    "url": "https://github.com/dustinlange/agent-minder",
    "json": true,
    "line-format": [
      { "field": "time", "timestamp-format": "%Y-%m-%dT%H:%M:%S%z" },
      " ",
      { "field": "level", "max-width": 5 },
      " ",
      { "field": "stage", "min-width": 9, "max-width": 9, "default-value": "-" },
      " ",
      { "field": "component", "min-width": 15, "max-width": 15, "default-value": "-" },
      " ",
      { "field": "msg" }
    ],
    "level": {
      "debug": "DEBUG",
      "info": "INFO",
      "warning": "WARN",
      "error": "ERROR"
    },
    "value": {
      "stage": {
        "kind": "string",
        "identifier": true
      },
      "step": {
        "kind": "string",
        "identifier": true
      },
      "component": {
        "kind": "string",
        "identifier": true
      },
      "model": {
        "kind": "string"
      },
      "item": {
        "kind": "string",
        "identifier": true
      },
      "project": {
        "kind": "string",
        "identifier": true
      },
      "commits": {
        "kind": "integer"
      },
      "messages": {
        "kind": "integer"
      },
      "items": {
        "kind": "integer"
      },
      "active": {
        "kind": "integer"
      },
      "previous": {
        "kind": "integer"
      },
      "duration_ms": {
        "kind": "integer"
      },
      "system_prompt": {
        "kind": "string",
        "hidden": true
      },
      "user_prompt": {
        "kind": "string",
        "hidden": true
      },
      "response": {
        "kind": "string",
        "hidden": true
      },
      "msg": {
        "kind": "string"
      }
    },
    "highlights": {
      "gather": {
        "pattern": "\"stage\":\"gather\"",
        "color": "#00ff00"
      },
      "tier1": {
        "pattern": "\"stage\":\"tier1\"",
        "color": "#5f87ff"
      },
      "tier2": {
        "pattern": "\"stage\":\"tier2\"",
        "color": "#ff8c00"
      },
      "sweep": {
        "pattern": "\"stage\":\"sweep\"",
        "color": "#af5fff"
      },
      "broadcast": {
        "pattern": "\"stage\":\"broadcast\"",
        "color": "#ff69b4"
      },
      "onboard": {
        "pattern": "\"stage\":\"onboard\"",
        "color": "#ffff00"
      },
      "publish": {
        "pattern": "\"stage\":\"publish\"",
        "color": "#00ffff"
      },
      "reconcile": {
        "pattern": "\"stage\":\"reconcile\"",
        "color": "#ff00ff"
      }
    }
  }
}
