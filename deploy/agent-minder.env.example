# agent-minder v2 deployment environment
# Copy to /etc/agent-minder/agent-minder.env and fill in values.
# Permissions should be 0600, owned by root:minder.

# --- Required ---

# GitHub personal access token (repo scope + read:org for private repos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API key for the daemon HTTP API (generate with: openssl rand -hex 32)
MINDER_API_KEY=

# --- Watch filter (set ONE) ---

# Watch for issues with this label:
WATCH_FILTER=label:agent-ready

# Or watch a milestone:
# WATCH_FILTER=milestone:v2.0

# --- Agent settings ---

# Max concurrent agents (default: 3)
# MAX_AGENTS=3

# Max turns per agent (default: 50)
# MAX_TURNS=50

# Per-job budget in USD (default: 5.00)
# BUDGET=5.00

# Total deployment budget in USD (default: 25.00)
# TOTAL_BUDGET=25.00

# Auto-merge low-risk reviewed PRs (default: false)
# AUTO_MERGE=true

# Base branch for worktrees/PRs (default: auto-detect)
# BASE_BRANCH=main

# --- HTTP API ---

# Address for the HTTP API server (default: :7749)
# SERVE_ADDR=:7749

# --- Paths ---

# Override database path (default: ~/.agent-minder/v2.db)
# MINDER_DB=/home/minder/.agent-minder/v2.db

# Override debug log path (default: ~/.agent-minder/debug.log)
# MINDER_LOG=/home/minder/.agent-minder/debug.log

# Enable structured JSON debug logging
# MINDER_DEBUG=1
