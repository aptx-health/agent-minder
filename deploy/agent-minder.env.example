# agent-minder deployment environment
# Copy to /etc/agent-minder/agent-minder.env and fill in values.
# Permissions should be 0600, owned by root:minder.

# --- Required ---

# GitHub personal access token (repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API key for the daemon HTTP API (generate with: openssl rand -hex 32)
MINDER_API_KEY=

# What to watch — set ONE of these:
WATCH_MILESTONE=v1.0
# WATCH_LABEL=ready-for-agent

# --- Agent settings ---

# Max concurrent agents (default: 5)
# MAX_AGENTS=5

# Max turns per agent (default: 150)
# MAX_TURNS=150

# Max budget per agent in USD (default: 10.00)
# MAX_BUDGET=10.00

# Total spend ceiling in USD, 0 = no limit (default: 50.00)
# TOTAL_BUDGET=50.00

# GitHub poll interval in seconds (default: 300)
# POLL_INTERVAL=300

# --- HTTP API ---

# Address for the HTTP API server (default: :7749)
# SERVE_ADDR=:7749

# Deploy ID for daemon identification (default: vps-daemon)
# DEPLOY_ID=vps-daemon

# --- Discord bot (optional) ---

# DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=
# DISCORD_GUILD_ID=

# --- Paths ---

# Override database path (default: ~/.agent-minder/minder.db)
# MINDER_DB=/home/minder/.agent-minder/minder.db

# Override debug log path (default: ~/.agent-minder/debug.log)
# MINDER_LOG=/home/minder/.agent-minder/debug.log

# Enable structured JSON debug logging
# MINDER_DEBUG=1
