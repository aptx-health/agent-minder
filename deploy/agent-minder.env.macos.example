# agent-minder macOS LaunchAgent environment
# Copy to ~/.agent-minder/deploy/agent-minder.env and fill in values.
#
# This file is sourced by start-daemon-macos.sh. Lines starting with #
# are comments. Uncomment and set values as needed.

# --- Required ---

# GitHub personal access token (repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Path to the git repo agents will work on
AGENT_MINDER_REPO=/Users/YOU/repos/your-repo

# What to watch — set ONE of these:
WATCH_MILESTONE=v1.0
# WATCH_LABEL=ready-for-agent

# --- Agent settings ---

# Max concurrent agents (default: 5)
# MAX_AGENTS=5

# Max turns per agent (default: 150)
# MAX_TURNS=150

# Max budget per agent in USD (default: 10.00)
# MAX_BUDGET=10.00

# Total spend ceiling in USD, 0 = no limit (default: 50.00)
# TOTAL_BUDGET=50.00

# GitHub poll interval in seconds (default: 300)
# POLL_INTERVAL=300

# Inherit settings from an existing agent-minder project
# WATCH_PROJECT=my-project

# --- HTTP API (optional) ---

# Enable the HTTP API server (required for Discord bot and remote status)
# SERVE_ADDR=:7749

# API key for HTTP server authentication (generate: openssl rand -hex 32)
# MINDER_API_KEY=

# --- Discord bot (optional, requires SERVE_ADDR) ---

# DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=
# DISCORD_GUILD_ID=

# --- Paths ---

# Override database path (default: ~/.agent-minder/minder.db)
# MINDER_DB=/Users/YOU/.agent-minder/minder.db

# Enable structured JSON debug logging
# MINDER_DEBUG=1

# --- Advanced ---

# Extra PATH entries (prepended to the launchd PATH)
# PATH_EXTRA=/some/custom/bin
